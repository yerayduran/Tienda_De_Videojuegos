<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<javafx.scene.layout.StackPane fx:id="overlayPaneContainer" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.micoleccion.controller.VideojuegoController" prefWidth="1300.0" prefHeight="750.0" style="-fx-background-color: transparent;">
    <BorderPane fx:id="mainContent" stylesheets="@../css/VideojuegoController.css" styleClass="root-pane">
    <top>
        <VBox spacing="12.0" styleClass="top-panel">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <HBox alignment="CENTER_RIGHT" spacing="10" onMousePressed="#onMousePressed" onMouseDragged="#onMouseDragged" style="-fx-cursor: hand;">
                <Label text="CanalOcio" styleClass="titulo-principal" HBox.hgrow="ALWAYS" maxWidth="Infinity" alignment="CENTER_LEFT" />
                <Button text="—" onAction="#onMinimizar" styleClass="btn-ventana"/>
                <Button text="X" onAction="#onCerrar" styleClass="btn-ventana-cerrar"/>
            </HBox>

            <HBox spacing="10.0">
                <TextField fx:id="txtBuscarTitulo" promptText="Buscar por titulo..." HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cbGeneroFiltro" promptText="Genero" prefWidth="180"/>
                <ComboBox fx:id="cbPlataformaFiltro" promptText="Plataforma" prefWidth="180"/>
                <Button text="Buscar" onAction="#onBuscar" styleClass="btn-primario"/>
                <Button text="Limpiar" onAction="#onLimpiarFiltros" styleClass="btn-secundario"/>
            </HBox>
            <Separator/>
            <HBox spacing="10.0">
                <Button text="Nuevo" onAction="#onNuevo" styleClass="btn-primario"/>
                <Button text="Editar" onAction="#onEditar" styleClass="btn-secundario"/>
                <Button text="Eliminar" onAction="#onEliminar" styleClass="btn-peligro"/>
                <Button text="Recargar" onAction="#onRecargar" styleClass="btn-secundario"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="8.0" styleClass="center-panel">
            <padding>
                <Insets top="0" right="16" bottom="16" left="16"/>
            </padding>

            <TableView fx:id="tvVideojuegos" VBox.vgrow="ALWAYS" styleClass="tabla-videojuegos">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colPortada" text="Portada" prefWidth="85" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colTitulo" text="Titulo" prefWidth="250"/>
                    <TableColumn fx:id="colPrecio" text="Precio" prefWidth="90" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colFechaCompra" text="Ult. compra" prefWidth="110" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colGenero" text="Genero(s)" prefWidth="140"/>
                    <TableColumn fx:id="colPlataformas" text="Plataformas" prefWidth="260"/>
                    <TableColumn fx:id="colAño" text="Año" prefWidth="70" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colNota" text="Nota" prefWidth="120" style="-fx-alignment: CENTER_LEFT;"/>                </columns>
            </TableView>

            <Label fx:id="lblEstado" text="0 videojuegos cargados" styleClass="lbl-estado"/>
        </VBox>
    </center>
    </BorderPane>

    <javafx.scene.layout.StackPane fx:id="overlayPane" visible="false" style="-fx-background-color: rgba(0, 0, 0, 0.75); -fx-background-radius: 12px;"/>
</javafx.scene.layout.StackPane>