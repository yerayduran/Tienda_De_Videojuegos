<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="overlayPaneContainer" prefHeight="750.0" prefWidth="1300.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.micoleccion.controller.VideojuegoController">

    <BorderPane fx:id="mainContent" styleClass="root-pane" stylesheets="@../css/VideojuegoController.css">
        <top>
            <VBox spacing="12.0" styleClass="top-panel">
                <padding>
                    <Insets bottom="16" left="16" right="16" top="16" />
                </padding>

                <!-- Barra superior personalizada -->
                <HBox alignment="CENTER_RIGHT" onMouseDragged="#onMouseDragged" onMousePressed="#onMousePressed" spacing="10" style="-fx-cursor: hand;">
                    <Label alignment="CENTER_LEFT" maxWidth="Infinity" styleClass="titulo-principal" text="CanalOcio" HBox.hgrow="ALWAYS" />
                    <Button onAction="#onMinimizar" styleClass="btn-ventana" text="—" />
                    <Button onAction="#onCerrar" styleClass="btn-ventana-cerrar" text="X" />
                </HBox>

                <!-- Barra de búsqueda y filtros -->
                <HBox spacing="10.0">
                    <TextField fx:id="txtBuscarTitulo" promptText="Buscar por titulo..." HBox.hgrow="ALWAYS" />
                    <ComboBox fx:id="cbGeneroFiltro" prefWidth="180" promptText="Genero" />
                    <ComboBox fx:id="cbPlataformaFiltro" prefWidth="180" promptText="Plataforma" />
                    <Button onAction="#onBuscar" styleClass="btn-primario" text="Buscar" />
                    <Button onAction="#onLimpiarFiltros" styleClass="btn-secundario" text="Limpiar" />
                </HBox>

                <Separator />

                <!-- Botones de acción -->
                <HBox spacing="10.0">
                    <Button onAction="#onNuevo" styleClass="btn-primario" text="Nuevo" />
                    <Button onAction="#onEditar" styleClass="btn-secundario" text="Editar" />
                    <Button onAction="#onEliminar" styleClass="btn-peligro" text="Eliminar" />
                    <Button onAction="#onRecargar" styleClass="btn-secundario" text="Recargar" />
                </HBox>
            </VBox>
        </top>

        <center>
            <VBox spacing="8.0" styleClass="center-panel">
                <padding>
                    <Insets bottom="16" left="16" right="16" top="0" />
                </padding>

                <!-- Tabla de datos -->
                <TableView fx:id="tvVideojuegos" styleClass="tabla-videojuegos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50" style="-fx-alignment: CENTER;" text="ID" />
                        <TableColumn fx:id="colPortada" prefWidth="85" style="-fx-alignment: CENTER;" text="Portada" />
                        <TableColumn fx:id="colTitulo" prefWidth="250" text="Titulo" />
                        <TableColumn fx:id="colPrecio" prefWidth="90" style="-fx-alignment: CENTER;" text="Precio" />
                        <TableColumn fx:id="colFechaCompra" prefWidth="110" style="-fx-alignment: CENTER;" text="Ult. compra" />
                        <TableColumn fx:id="colGenero" prefWidth="140" text="Genero(s)" />
                        <TableColumn fx:id="colPlataformas" prefWidth="260" text="Plataformas" />
                        <TableColumn fx:id="colAño" prefWidth="70" style="-fx-alignment: CENTER;" text="Año" />
                        <TableColumn fx:id="colNota" prefWidth="120" style="-fx-alignment: CENTER_LEFT;" text="Nota" />
                    </columns>
                </TableView>

                <Label fx:id="lblEstado" styleClass="lbl-estado" text="0 videojuegos cargados" />
            </VBox>
        </center>
    </BorderPane>

    <!-- Panel para modales (oscurece el fondo) -->
    <StackPane fx:id="overlayPane" style="-fx-background-color: rgba(0, 0, 0, 0.75); -fx-background-radius: 12px;" visible="false" />

</StackPane>